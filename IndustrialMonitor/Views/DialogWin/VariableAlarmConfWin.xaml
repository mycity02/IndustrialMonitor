<Window x:Class="IndustrialMonitor.Views.DialogWin.VariableAlarmConfWin"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       xmlns:converter="clr-namespace:IndustrialMonitor.Converter;assembly=IndustrialMonitor.Converter"
        mc:Ignorable="d"
       xmlns:localVM="clr-namespace:IndustrialMonitor.ViewModels"
        FontFamily="Microsoft YaHei" FontWeight="ExtraLight" FontSize="12"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Title="变量报警配置" Height="400" Width="600">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="1"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/IndustrialMonitor.CommonResource;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/IndustrialMonitor.CommonResource;component/Styles/ComboBoxStyles.xaml"/>

                <ResourceDictionary>
                    <converter:RowNumberConverter x:Key="rnc"/>
                </ResourceDictionary>

                <ResourceDictionary>
                    <localVM:AlarmConfViewModel x:Key="localAlarmVM"/>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="#F7F9FA">
        <Grid.Resources>
            <Style TargetType="TextBox">
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border BorderBrush="#EEE" BorderThickness="1" CornerRadius="3" MinHeight="26" Background="White" Name="bor">
                                <ScrollViewer Name="PART_ContentHost" Margin="0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="bor" Property="BorderBrush" Value="#16a1ff"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Background="#AA409EFE" Grid.RowSpan="3"/>
        <TextBlock Text="{Binding DeviceName,StringFormat={}{0}-变量报警配置}" Grid.Column="1" VerticalAlignment="Center" FontSize="15" Foreground="#BBB" Margin="10,0"/>

        <Button Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Style="{StaticResource WindowControlButtonStyle}" 
        WindowChrome.IsHitTestVisibleInChrome="True" Margin="10,0" Content="&#xe653;" FontFamily="{StaticResource Iconfont}"
        Width="30" Height="30" Click="BtnCancel_Click">
        </Button>

        <!--列出所有的变量，跟当前的编辑设备有关-->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Grid.RowSpan="2">
            <ListBox Background="Transparent" BorderThickness="0" SelectedIndex="0" Name="lb" ItemsSource="{Binding DeviceVarList}" Margin="0,5,-1,0" >
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border Height="1" Background="#2FFF" Grid.ColumnSpan="2" VerticalAlignment="Bottom"/>
                            <StackPanel Margin="0,3">
                                <TextBlock Text="{Binding VarName}" FontSize="13" Margin="0,0,0,3" Name="tb1" Opacity="0.9"/>
                                <TextBlock Text="{Binding VarAddress}" FontSize="10" Margin="0,3,0,5" Opacity="0.6"/>
                            </StackPanel>
                            <TextBlock Text="{Binding VarType}" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="Transparent" Name="border" TextBlock.Foreground="White"
                                BorderBrush="Transparent" BorderThickness="1,0,0,0">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#F7F9FA"/>
                                            <Setter TargetName="border" Property="TextBlock.Foreground" Value="#409EFE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </ScrollViewer>

        <!--当前选中变量的判断条件-->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Border Grid.Row="1" Height="1" Background="#EEE" VerticalAlignment="Bottom" Margin="10,0"/>
            <TextBlock Text="{Binding ElementName=lb,Path=SelectedItem.VarName}" VerticalAlignment="Center" Margin="10,0" FontWeight="Normal" Foreground="#555"/>
            <Grid Margin="10,5" Grid.Row="1" TextBlock.Foreground="#888">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="序号" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="预警条件" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="预警值" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="提醒内容信息" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="操作" Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <ScrollViewer Grid.Row="2" Grid.Column="1" VerticalScrollBarVisibility="Hidden">
                <ItemsControl ItemsSource="{Binding ElementName=lb,Path=SelectedItem.VarAlarmConfList}" 
                      AlternationCount="10000" Name="ic" Margin="10,5">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="28" Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding 
                                        Path=(ItemsControl.AlternationIndex),
                                        RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                        Converter={StaticResource rnc}, StringFormat={}{0:00}}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="#888"/>
                                <ComboBox Grid.Column="1" SelectedValue="{Binding Operator}" DisplayMemberPath="OperatorName" SelectedValuePath="OperatorSymbol"
                          ItemsSource="{Binding Source={StaticResource localAlarmVM}, Path=OperatorList}"
                              Style="{StaticResource PropComboBoxStyle}" Foreground="#555">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                        <Border Name="border" Background="Transparent" Height="23" CornerRadius="3">
                                                            <ContentPresenter VerticalAlignment="Center" Margin="3,0"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#336364f8"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#BB6364f8"/>
                                                                <Setter TargetName="border" Property="TextBlock.Foreground" Value="White"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                                <TextBox Text="{Binding CompareValue}" Grid.Column="2" HorizontalContentAlignment="Center" Margin="3,0"/>
                                <TextBox Text="{Binding AlarmContent}" Grid.Column="3"/>
                                <TextBlock Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Hyperlink TextDecorations="None" Command="{Binding ElementName=lb,Path=SelectedItem.DeleteConfCommand}" CommandParameter="{Binding}">删除</Hyperlink>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Button Style="{StaticResource NormalButtonStyle}" Command="{Binding ElementName=lb,Path=SelectedItem.AddConfCommand}" Background="Orange" Height="28" Margin="20,0" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
            <TextBlock Margin="15,0">
              <Run  Text="&#xe8fe;" FontFamily="{StaticResource Iconfont}"/>
              <Run Text="添加报警条件"/>
            </TextBlock>
        </Button>
    </Grid>
</Window>
