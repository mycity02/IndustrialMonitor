<UserControl x:Class="IndustrialMonitor.Views.FunctionUC.SettingsUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IndustrialMonitor.Views.FunctionUC"
             xmlns:converter="clr-namespace:IndustrialMonitor.Converter;assembly=IndustrialMonitor.Converter"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/IndustrialMonitor.CommonResource;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/IndustrialMonitor.CommonResource;component/Styles/ComboBoxStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/IndustrialMonitor.CommonResource;component/Styles/DataGridStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converter:RowNumberConverter x:Key="rnc"/>

            <Style TargetType="TabControl">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Background="White" CornerRadius="5" Margin="5"/>
                                <TabPanel x:Name="HeaderPanel" Grid.Row="0" Panel.ZIndex="1"
                                         Margin="5" IsItemsHost="True"
                                         KeyboardNavigation.TabIndex="1"
                                         Background="Transparent" />
                                <Border x:Name="Border" Grid.Column="1">
                                    <ContentPresenter x:Name="PART_SelectedContentHost" Margin="4" ContentSource="SelectedContent" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="TabItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="Border" Margin="2" CornerRadius="5" Background="Transparent">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center"
                                               HorizontalAlignment="Center" ContentSource="Header" 
                                               Margin="12,6" RecognizesAccessKey="True" />
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#1000" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#99409EFE" />
                                    <Setter TargetName="Border" Property="TextBlock.Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border BorderBrush="#EEE" BorderThickness="1" CornerRadius="3" MinHeight="26" Background="#DFFF" Name="bor">
                                <Grid>
                                    <TextBlock Text="{TemplateBinding Tag}" VerticalAlignment="Center" Margin="5,0" 
                                            FontSize="11" Foreground="#BBB" Name="mark"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            Visibility="Collapsed"/>
                                    <ScrollViewer Name="PART_ContentHost" Margin="5,0"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="bor" Property="BorderBrush" Value="#16a1ff"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding Path=Text,RelativeSource={RelativeSource Mode=Self}}" Value="">
                                    <Setter Property="Visibility" TargetName="mark" Value="Visible"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="80,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border BorderBrush="#EEE" BorderThickness="0,0,0,1"/>

        <Border Width="3" Height="15" Background="Gold" HorizontalAlignment="Left" CornerRadius="2"/>
        <TextBlock Text="系统平台配置选项" VerticalAlignment="Center" HorizontalAlignment="Left"
                 Foreground="#AA409EFE" FontSize="18" FontWeight="Normal" Margin="10,0,0,0">
            <TextBlock.Effect>
                <DropShadowEffect Color="White" ShadowDepth="0" BlurRadius="10" Opacity="0.8"/>
            </TextBlock.Effect>
        </TextBlock>

        <Border Background="#5FFF" Grid.Row="1"  CornerRadius="0,0,5,5"/>

        <TabControl Grid.Row="1" TabStripPlacement="Left">
            <TabItem Header="监控配置">
                <!--配置车间温度、湿度、.......-->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.1*"/>
                        <ColumnDefinition MinWidth="300"/>
                        <ColumnDefinition Width="0.3*"/>
                    </Grid.ColumnDefinitions>

                    <ItemsControl Grid.Column="1" Margin="0,20" ItemsSource="{Binding MonitorSettingList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="15"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding Header}" FontSize="15" Foreground="#555"/>
                                    <TextBlock Text="{Binding Description}" FontSize="12" Grid.Row="1" Foreground="#AAA"/>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <TextBlock Text="选择设备" Foreground="#999" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" Style="{StaticResource PropComboBoxStyle}" Margin="5,0"
                                                SelectedValue="{Binding DeviceNum}"
                                                SelectedValuePath="DeviceNum"
                                                DisplayMemberPath="DeviceName"
                                                ItemsSource="{Binding DeviceList}"/>
                                        <TextBlock Text="选择变量" Margin="10,0,5,0" Foreground="#999" VerticalAlignment="Center"/>
                                        <ComboBox Width="220" Style="{StaticResource PropComboBoxStyle}" 
                                                SelectedValue="{Binding VarNum}"
                                                SelectedValuePath="VarNum"
                                                DisplayMemberPath="VarName"
                                                ItemsSource="{Binding VarList}"/>
                                    </StackPanel>
                                    <Border BorderThickness="0,0,0,1" BorderBrush="#DDD" Grid.Row="3" Grid.ColumnSpan="2" SnapsToDevicePixels="True" VerticalAlignment="Center" Margin="-10,0">
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="30" Width="100" Grid.Column="1" Style="{StaticResource NormalButtonStyle}" Command="{Binding SaveMonitorSetsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xe63c;" FontFamily="{StaticResource Iconfont}" VerticalAlignment="Center" Margin="3,0"/>
                            <TextBlock Text="保存监测配置" VerticalAlignment="Center" Margin="3,0"/>
                        </StackPanel>
                    </Button>

                </Grid>
            </TabItem>
            
            <TabItem Header="用户管理">
                <!--用户增删查-->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.1*"/>
                        <ColumnDefinition MinWidth="300"/>
                        <ColumnDefinition Width="0.3*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="1" Margin="0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="系统注册用户" FontSize="15" Foreground="#555"/>
                        <Border BorderThickness="0,0,0,1" BorderBrush="#DDD" Grid.Row="1" SnapsToDevicePixels="True" VerticalAlignment="Center" Margin="-10,5"/>
                        <Button VerticalAlignment="Center" HorizontalAlignment="Right" Height="30" Style="{StaticResource WindowControlButtonStyle}" Command="{Binding AddUserCommand}">
                            <TextBlock Margin="10,0">
                              <Run Text="&#xe8fe;" FontFamily="{StaticResource Iconfont}"/>
                              <Run Text="添加新用户"/>
                            </TextBlock>
                        </Button>

                        <Border Grid.Row="2" Background="#22409EFE" CornerRadius="3" Margin="0,1"/>
                        <Grid Grid.Row="2" TextBlock.Foreground="#999">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="序号" HorizontalAlignment="Center"/>
                            <TextBlock Text="登录账号" HorizontalAlignment="Center" Grid.Column="1"/>
                            <TextBlock Text="真实姓名" Grid.Column="2" HorizontalAlignment="Center"/>
                            <TextBlock Text="用户类型" Grid.Column="3" HorizontalAlignment="Center"/>
                            <TextBlock Text="部门" Grid.Column="4" HorizontalAlignment="Center"/>
                            <TextBlock Text="操作" Grid.Column="5" HorizontalAlignment="Center"/>
                        </Grid>

                        <ItemsControl Grid.Row="3" ItemsSource="{Binding UserList}" AlternationCount="1000">
                            <ItemsControl.Resources>
                                <Style TargetType="TextBox">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border BorderBrush="Transparent" BorderThickness="1" 
                                                      CornerRadius="3" MinHeight="28" Background="Transparent" Name="bor">
                                                    <Grid>
                                                        <TextBlock Text="{TemplateBinding Tag}" VerticalAlignment="Center" Margin="5,0" 
                                             FontSize="11" Foreground="#BBB" Name="mark"
                                             HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                             Visibility="Collapsed"/>
                                                        <ScrollViewer Name="PART_ContentHost" Margin="0"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter TargetName="bor" Property="BorderBrush" Value="#16a1ff"/>
                                                        <Setter TargetName="bor" Property="Background" Value="#DFFF"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding Path=Text,RelativeSource={RelativeSource Mode=Self}}" Value="">
                                                        <Setter Property="Visibility" TargetName="mark" Value="Visible"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ItemsControl.Resources>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="35" Background="White">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Grid.ColumnSpan="6" Name="grid"/>
                                        <TextBlock Text="{Binding  Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, Converter={StaticResource rnc},  StringFormat={}{0:00}}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#888"/>
                                        <TextBox Text="{Binding Account}" Grid.Column="1"/>
                                        <TextBox Text="{Binding RealName}" Grid.Column="2"/>
                                        <ComboBox SelectedValue="{Binding IsAdmin}" 
                                                Grid.Column="3"
                                                Style="{StaticResource PropComboBoxStyle}"
                                                VerticalAlignment="Center" Height="26" Margin="5,0"
                                                ItemsSource="{Binding DataContext.UserTypeList,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                DisplayMemberPath="TypeName" SelectedValuePath="IsAdmin"/>
                                        <TextBox Text="{Binding Department}" Grid.Column="4"/>
                                        <TextBlock Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                          <Hyperlink Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl},
                                              Path=DataContext.ResetPwdCommand}" CommandParameter="{Binding}">重置密码</Hyperlink>
                                          <Run Text=" "/>
                                          <Hyperlink Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl},
                                              Path=DataContext.DelUserCommand}" CommandParameter="{Binding}">删除</Hyperlink>
                                        </TextBlock>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="grid" Property="Background" Value="#1999"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <Button HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="30" Width="100" Grid.Column="1" Style="{StaticResource NormalButtonStyle}" Command="{Binding SaveUserSetsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xe63c;" FontFamily="{StaticResource Iconfont}" VerticalAlignment="Center" Margin="3,0"/>
                            <TextBlock Text="保存用户配置" VerticalAlignment="Center" Margin="3,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
