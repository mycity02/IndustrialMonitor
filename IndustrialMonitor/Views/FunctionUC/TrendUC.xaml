<UserControl x:Class="IndustrialMonitor.Views.FunctionUC.TrendUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/IndustrialMonitor.CommonResource;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/IndustrialMonitor.CommonResource;component/Styles/ComboBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="80,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="72"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1"/>
        <Border Width="3" Height="16" Background="Gold" HorizontalAlignment="Left" CornerRadius="2"/>
        <TextBlock Text="实时趋势" Margin="12,0,0,0" VerticalAlignment="Center"
                   Foreground="#409EFE" FontSize="20"/>

        <Border Grid.Row="1" Margin="0,10,0,10" Padding="14,8"
                Background="White" BorderBrush="#E1E6ED" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="设备" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                          DisplayMemberPath="DeviceName" Margin="0,0,18,0"/>

                <TextBlock Grid.Column="2" Text="变量" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="3" ItemsSource="{Binding Variables}"
                          SelectedItem="{Binding SelectedVariable, Mode=TwoWay}"
                          DisplayMemberPath="VarName" Margin="0,0,18,0"/>

                <Button Grid.Column="4" Content="{Binding RunButtonText}"
                        Command="{Binding ToggleSamplingCommand}"
                        Style="{StaticResource NormalButtonStyle}" Margin="0,0,8,0"
                        Background="#409EFE" Foreground="White"/>
                <Button Grid.Column="5" Content="清空" Command="{Binding ClearCommand}"
                        Style="{StaticResource NormalButtonStyle}" Margin="0,0,8,0"/>

                <TextBlock Grid.Column="6" Text="{Binding StatusText}" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Foreground="#7D8795"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" BorderBrush="#E1E6ED"
                BorderThickness="1" CornerRadius="6" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Border Background="#F3F8FE" CornerRadius="5">
                    <Grid>
                        <TextBlock Text="{Binding ChartTitle}" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" FontSize="18" Foreground="#409EFE"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Margin="0,0,18,0">
                            <TextBlock Text="当前值：" Foreground="#7D8795"/>
                            <TextBlock Text="{Binding CurrentValueText}" FontSize="18"
                                       FontWeight="SemiBold" Foreground="#333333"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <lvc:CartesianChart Grid.Row="1" Margin="4,12,4,4"
                                    Series="{Binding ChartSeries}"
                                    LegendLocation="None"
                                    DisableAnimations="True">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="时间" Labels="{Binding TimeLabels}" LabelsRotation="-25">
                            <lvc:Axis.Separator>
                                <lvc:Separator Step="5" StrokeThickness="1" Stroke="#EEF1F5"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="数值">
                            <lvc:Axis.Separator>
                                <lvc:Separator StrokeThickness="1" Stroke="#EEF1F5"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>
    </Grid>
</UserControl>
