<Window x:Class="IndustrialMonitor.Views.DeviceWin.DeviceManageWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        mc:Ignorable="d"
        x:Name="win"
        Title="设备管理"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1677FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#D5D9DE"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E8EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E5E8EC" BorderThickness="0,0,0,1" Padding="22,12">
            <StackPanel>
                <TextBlock Text="设备管理" FontSize="22" FontWeight="SemiBold" Foreground="#222222"/>
                <TextBlock Text="配置少量通信设备、连接参数和寄存器变量；不再使用拖拽组态。"
                           Margin="0,5,0,0" Foreground="#777777"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionBorder}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="设备列表" FontSize="16" FontWeight="SemiBold" Margin="4,0,0,12"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding DeviceList}"
                             SelectedItem="{Binding SelectedDevice}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="0,0,0,6" Background="#F6F8FA" CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold" Foreground="#333333"/>
                                        <TextBlock Text="{Binding DeviceNum}" FontSize="11" Foreground="#888888" Margin="0,3,0,0"/>
                                        <TextBlock FontSize="11" Foreground="#888888" Margin="0,3,0,0">
                                            <Run Text="变量 "/><Run Text="{Binding DeviceVarList.Count, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Text="基本信息" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="设备编号" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Margin="5" Padding="7,5"
                                         Text="{Binding SelectedDevice.DeviceNum, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="2" Text="设备名称" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                <TextBox Grid.Column="3" Margin="5" Padding="7,5"
                                         Text="{Binding SelectedDevice.DeviceName, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Text="通信设置" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="先选择连接方式，再填写设备连接信息。"
                                       Foreground="#777777" Margin="0,5,0,14"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="280"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="连接方式" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          Margin="5,0"
                                          Padding="8,6"
                                          ItemsSource="{Binding ProtocolOptions}"
                                          DisplayMemberPath="Value"
                                          SelectedValuePath="Key"
                                          SelectedValue="{Binding CommunicationProtocol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="2"
                                           Text="RTU 使用串口；TCP 使用网络。"
                                           Foreground="#888888"
                                           VerticalAlignment="Center"
                                           Margin="14,0,0,0"/>
                            </Grid>

                            <Border Background="#F7F9FB" CornerRadius="5" Padding="14" Margin="0,0,0,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CommunicationProtocol}" Value="ModbusRTU">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="串口连接" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="串口" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Margin="5" Padding="7,5"
                                                  IsEditable="True"
                                                  ItemsSource="{Binding SerialPortOptions}"
                                                  Text="{Binding PortName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Column="2" Text="波特率" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                        <ComboBox Grid.Column="3" Margin="5" Padding="7,5"
                                                  IsEditable="True"
                                                  ItemsSource="{Binding BaudRateOptions}"
                                                  Text="{Binding BaudRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Row="1" Text="数据位" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" Margin="5" Padding="7,5"
                                                  ItemsSource="{Binding DataBitsOptions}"
                                                  SelectedItem="{Binding DataBits, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="校验位" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                        <ComboBox Grid.Row="1" Grid.Column="3" Margin="5" Padding="7,5"
                                                  ItemsSource="{Binding ParityOptions}"
                                                  SelectedItem="{Binding Parity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Row="2" Text="停止位" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1" Margin="5" Padding="7,5"
                                                  ItemsSource="{Binding StopBitsOptions}"
                                                  SelectedItem="{Binding StopBits, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="#F7F9FB" CornerRadius="5" Padding="14" Margin="0,0,0,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CommunicationProtocol}" Value="ModbusTCP">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="网络连接" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="IP地址" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Margin="5" Padding="7,5"
                                                 Text="{Binding IpAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Column="2" Text="端口" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                        <TextBox Grid.Column="3" Margin="5" Padding="7,5"
                                                 Text="{Binding TcpPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="通用参数" FontWeight="SemiBold" Margin="0,2,0,8"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="从站地址" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Margin="5" Padding="7,5"
                                         Text="{Binding SlaveId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="2" Text="采集周期(ms)" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                <TextBox Grid.Column="3" Margin="5" Padding="7,5"
                                         Text="{Binding RefreshRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="1" Text="超时(ms)" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="5" Padding="7,5"
                                         Text="{Binding Timeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="重试次数" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Margin="5" Padding="7,5"
                                         Text="{Binding TryCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10" LastChildFill="False">
                                <TextBlock Text="监控变量" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="阈值配置" Command="{Binding AlarmConfCommand}" Style="{StaticResource SecondaryButton}"/>
                                    <Button Content="新增变量" Command="{Binding AddVariableCommand}" Style="{StaticResource SecondaryButton}"/>
                                    <Button Content="删除变量" Command="{Binding DeleteVariableCommand}" Style="{StaticResource SecondaryButton}"/>
                                </StackPanel>
                            </DockPanel>
                            <DataGrid ItemsSource="{Binding SelectedDevice.DeviceVarList}"
                                      SelectedItem="{Binding SelectedVariable}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      Height="210"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="变量名称" Binding="{Binding VarName, UpdateSourceTrigger=PropertyChanged}" Width="1.4*"/>
                                    <DataGridTextColumn Header="地址" Binding="{Binding VarAddress, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="数据类型" Binding="{Binding VarType, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="系数" Binding="{Binding Modulus, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="偏移" Binding="{Binding Offset, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="变量编号" Binding="{Binding VarNum}" IsReadOnly="True" Width="1.8*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="常用数据类型：Boolean、UInt16、Int16、UInt32、Int32、Single、Double"
                                       Foreground="#888888" FontSize="11" Margin="0,7,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10" LastChildFill="False">
                                <TextBlock Text="手动控制（可选）" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="新增控制" Command="{Binding AddManualControlCommand}" Style="{StaticResource SecondaryButton}"/>
                                    <Button Content="删除控制" Command="{Binding DeleteManualControlCommand}" Style="{StaticResource SecondaryButton}"/>
                                </StackPanel>
                            </DockPanel>
                            <DataGrid ItemsSource="{Binding SelectedDevice.ManualControlList}"
                                      SelectedItem="{Binding SelectedManualControl}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      Height="150">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="名称" Binding="{Binding ControlName, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="写入地址" Binding="{Binding ControlAddress, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="写入值" Binding="{Binding ControlValue, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#E5E8EC" BorderThickness="0,1,0,0" Padding="16,8">
            <DockPanel LastChildFill="False">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#D4380D" VerticalAlignment="Center" Margin="8,0"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Command="{Binding CloseCommand}" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="保存并应用" Command="{Binding SaveDevicesCommand}" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>