<UserControl x:Class="IndustrialMonitor.Components.WidthRule"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IndustrialMonitor.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="5,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Line X1="0" Y1="0" X2="0" Y2="20" Width="1" Stroke="Orange" StrokeDashArray="3,3" ClipToBounds="True"/>

        <Line X1="0" Y1="0"  X2="{Binding RelativeSource={RelativeSource Self},Path=ActualWidth}" Y2="0" Height="1" Stroke="Orange" ClipToBounds="True" Grid.Column="1" VerticalAlignment="Center" StrokeDashArray="3,3"/>

        <Line X1="0" Y1="0" X2="0" Y2="20" Width="1" Stroke="Orange"  StrokeDashArray="3,3" ClipToBounds="True" Grid.Column="2"/>

      
    </Grid>
</UserControl>
